<ehcache xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             updateCheck="false"
       xsi:noNamespaceSchemaLocation="ehcache.xsd" name="epdsHibernateCacheManager">
     <diskStore path="java.io.tmpdir"/>
     
     <cache name="docInfo" maxEntriesLocalHeap="10000" eternal="false"
		timeToIdleSeconds="3600" timeToLiveSeconds="86400">
		<!-- <persistence strategy="localTempSwap" /> -->
	</cache>
	
	
     <!-- <cache name="yourEntityCache"
            maxEntriesLocalHeap="10000"
            eternal="false"
            overflowToDisk="false"
            timeToLiveSeconds="86400" /> -->
     <cache name="org.hibernate.cache.internal.StandardQueryCache"
            maxElementsInMemory="10000"
            eternal="false"
            timeToLiveSeconds="86400"
            overflowToDisk="false"
            memoryStoreEvictionPolicy="LRU" />
  <defaultCache
          maxElementsInMemory="10000"
          eternal="false"
          timeToLiveSeconds="86400"
          overflowToDisk="false"
          memoryStoreEvictionPolicy="LRU" />
</ehcache>